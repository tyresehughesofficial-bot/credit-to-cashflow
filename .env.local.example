# ─────────────────────────────────────────────────────────────
# TRIAD T ENTERPRISE AI COMMAND CENTER — Environment Variables
# Copy this file to `.env.local` and fill in your values.
# ─────────────────────────────────────────────────────────────

# Supabase — find these in your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key (never expose to the browser). Used for admin tasks/seeding.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider — text generation (Prolific AI Strategist + future features).
# Runs in the `generate-text` Edge Function. Set as a SUPABASE FUNCTION SECRET
# only (never NEXT_PUBLIC_, never committed):
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   supabase functions deploy generate-text --no-verify-jwt
# Optional: CLAUDE_MODEL (default claude-sonnet-4-6). Without it, AI features
# fall back to the deterministic generators automatically.
ANTHROPIC_API_KEY=

# ── Creative Asset Generation Engine (Motion Graphics Studio) ──
# Generation runs in the Supabase Edge Function `generate-image`:
#   Claude (Creative Director) → Flux (renderer) → Supabase Storage + DB.
# All provider keys are SUPABASE FUNCTION SECRETS — never NEXT_PUBLIC_ / never here:
#   supabase secrets set FAL_KEY=...                # default renderer (fal.ai Flux)
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...   # Claude prompt engineering
#   supabase secrets set OPENAI_API_KEY=sk-...      # backup provider (optional)
#   # ADOBE_FIREFLY_CLIENT_ID / ADOBE_FIREFLY_CLIENT_SECRET  # future
# Optional overrides: FAL_MODEL (default fal-ai/flux/dev), CLAUDE_MODEL.
# The frontend only needs the public Supabase URL + anon key (above).

# ── MyFreeScoreNow integration (Client Command Center) ──
# Runs in the Supabase Edge Function `mfsn_import`. The token NEVER touches the
# browser — set it as a SUPABASE FUNCTION SECRET only:
#   supabase secrets set MFSN_API_KEY=...
# Optional endpoint overrides (fill from your Secure API Control docs):
#   supabase secrets set MFSN_BASE_URL=https://api.myfreescorenow.com/v1
#   supabase secrets set MFSN_AUTH_HEADER=Authorization   # or X-API-Key
#   supabase secrets set MFSN_AUTH_PREFIX="Bearer "       # or "" for raw key
#   supabase secrets set MFSN_EP_LIST_MEMBERS=/members
#   supabase secrets set MFSN_EP_MEMBER=/members/{id}
#   supabase secrets set MFSN_EP_REPORT=/members/{id}/report
# Deploy:  supabase functions deploy mfsn_import --no-verify-jwt
# Without MFSN_API_KEY the function runs in safe DEMO mode.
