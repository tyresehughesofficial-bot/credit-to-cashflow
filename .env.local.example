# ─────────────────────────────────────────────────────────────
# TRIAD T ENTERPRISE AI COMMAND CENTER — Environment Variables
# Copy this file to `.env.local` and fill in your values.
# ─────────────────────────────────────────────────────────────

# Supabase — find these in your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key (never expose to the browser). Used for admin tasks/seeding.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider (Phase 2 — content/script/dispute generation).
# The app ships with deterministic local generators so it runs without this.
ANTHROPIC_API_KEY=

# ── Creative Asset Generation Engine (Motion Graphics Studio) ──
# Image generation runs in the Supabase Edge Function `generate-image`.
# The OpenAI key is a SUPABASE FUNCTION SECRET — never a NEXT_PUBLIC_ var and
# never in this file:
#   supabase secrets set OPENAI_API_KEY=sk-...
# The frontend only needs the public Supabase URL + anon key (above) to invoke
# the function. Adobe Firefly is future-ready (same function, new branch).
