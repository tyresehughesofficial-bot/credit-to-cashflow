# ─────────────────────────────────────────────────────────────
# TRIAD T ENTERPRISE AI COMMAND CENTER — Environment Variables
# Copy this file to `.env.local` and fill in your values.
# ─────────────────────────────────────────────────────────────

# Supabase — find these in your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key (never expose to the browser). Used for admin tasks/seeding.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider (Phase 2 — content/script/dispute generation).
# The app ships with deterministic local generators so it runs without this.
ANTHROPIC_API_KEY=

# ── Creative Asset Generation Engine (Motion Graphics Studio) ──
# OpenAI Images: when set, the Creative Studio renders real images in-app.
# (Public var works for the static preview; move server-side for production.)
NEXT_PUBLIC_OPENAI_API_KEY=
# Adobe Firefly (server-side OAuth client-credentials — Phase 2 server route).
ADOBE_FIREFLY_CLIENT_ID=
ADOBE_FIREFLY_CLIENT_SECRET=
